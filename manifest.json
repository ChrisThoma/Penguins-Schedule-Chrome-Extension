{
    "name": "Penguins 2026-2027 Schedule",
    "description": "A quick way to view the schedule for the Pittsburgh Penguins 2026-2027 NHL Season.",
    "version" : "2.1.0",
    "manifest_version": 3,
    "permissions": ["alarms", "notifications"],
    "action": {
        "default_icon": "icon.png",
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js",
        "scripts": ["background.js"]
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "penguins-schedule@christhoma.proton.me",
            "strict_min_version": "140.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "icons": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon.png"
    }
}
